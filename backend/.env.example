# Providers
TRANSCRIPTION_PROVIDER=sarvam  # gemini or sarvam
AI_PROVIDER=openrouter             # gemini, openai, or openrouter

# OpenRouter (Great for FREE models like Gemini 2.0 Flash Exp)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# Sarvam
SARVAM_API_KEY=your-sarvam-key
SARVAM_RECOGNITION_MODEL=saaras:v3

# OpenAI (Alternative for analysis)
OPEN_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Database
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db
